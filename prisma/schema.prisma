generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id  String  @id @default(uuid())
  username String 
  password String
}

model Kecamatan {
  id Int @id @default(autoincrement())
  kecamatan  String @unique
  SerutiEntri  SerutiEntri[]
  SerutiMasuk  SerutiMasuk[]
  SusenasEntri  SusenasEntri[]
  SusenasMasuk  SusenasMasuk[]
}

model SerutiEntri {
  id                 Int      @id @default(autoincrement())
  kecamatanId Int 
  provinsi           String
  kabupaten          String
  kecamatan     Kecamatan @relation(fields: [kecamatanId], references: [id])
  nagari             String
  sls                String
  kode_sls_subsls    String
  nks             String @unique
  no_ruta            String
  nama_petugas_entri String
  tgl_entri          DateTime

  @@map("seruti_entri")
}

model SerutiMasuk {
  id              Int      @id @default(autoincrement())
  kecamatanId Int
  provinsi        String
  kabupaten       String
  kecamatan     Kecamatan @relation(fields: [kecamatanId], references: [id])
  nagari          String
  sls             String
  kode_sls_subsls String
  nks             String @unique
  nama_PML        String
  nama_PPL        String
  no_ruta         String
  tgl_masuk       DateTime

  @@map("seruti_masuk")
}
model SusenasEntri {
  id                 Int      @id @default(autoincrement())
  kecamatanId Int
  provinsi           String
  kabupaten          String
  kecamatan     Kecamatan @relation(fields: [kecamatanId], references: [id])
  nagari             String
  sls                String
  kode_sls_subsls    String
  nks             String @unique
  no_ruta            String
  nama_petugas_entri String
  tgl_entri          DateTime

  @@map("susenas_entri")
}


model SusenasMasuk {
  id              Int      @id @default(autoincrement())
  kecamatanId Int
  provinsi        String
  kabupaten       String
  kecamatan     Kecamatan @relation(fields: [kecamatanId], references: [id])
  nagari          String
  sls             String
  kode_sls_subsls String
  nks             String @unique
  nama_PML        String
  nama_PPL        String
  no_ruta         String
  tgl_masuk       DateTime

  @@map("susenas_masuk")
}

model UploadedFile {
  id        Int      @id @default(autoincrement())
  filename  String
  path      String
  createdAt DateTime @default(now())
}
